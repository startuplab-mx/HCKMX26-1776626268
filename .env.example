# Configuración compartida entre `app`, `server` y `dashboard`.
#
# Cópialo a `.env` (que está en .gitignore) y rellena el token con un
# valor secreto. Cada equipo / ambiente debe usar su propio token.
#
# Genera uno seguro con:  openssl rand -hex 32

# Token bearer para autenticar requests app↔server↔dashboard. OBLIGATORIO:
SHIELD_AUTH_TOKEN=

# URL del server Actix. Default: http://127.0.0.1:7878. Sólo cambia esto
# si el server corre en otra máquina o puerto.
# SHIELD_SERVER_URL=http://127.0.0.1:7878

# Bind del server (sólo lo lee `server`). Default: 127.0.0.1:7878.
# Para exponerlo en LAN: 0.0.0.0:7878.
# SERVER_BIND=127.0.0.1:7878
